<Project Sdk="Microsoft.Build.NoTargets">
  <Import Project="ZigVersion.props" />
  <Import Project="..\toolsets\ToolsetsVersion.props" />

  <PropertyGroup>

    <TargetFramework>netstandard2.0</TargetFramework>

    <PackageId>Fallenwood.PublishAotCross</PackageId>
    <Version Condition="'$(Version)' == ''">42.42.42-dev</Version>
    <Authors>Michal Strehovsky;Fallenwood</Authors>
    <Company>Fallenwood</Company>
    <Description>MSBuild targets to aid in crosscompiling Native AOT publishing.</Description>
    <PackageProjectUrl>https://github.com/Fallenwood/PublishAotCross</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Vezel.Zig.Toolsets.win-x64" Version="$(ZigVersion)" GeneratePathProperty="true" />
    <PackageReference Include="Vezel.Zig.Toolsets.win-arm64" Version="$(ZigVersion)" GeneratePathProperty="true" />
    <PackageReference Include="Vezel.Zig.Toolsets.win-x86" Version="$(ZigVersion)" GeneratePathProperty="true" />
    <PackageReference Include="Vezel.Zig.Toolsets.linux-x64" Version="$(ZigVersion)" GeneratePathProperty="true" />
    <PackageReference Include="Vezel.Zig.Toolsets.linux-arm64" Version="$(ZigVersion)" GeneratePathProperty="true" />
    <PackageReference Include="Vezel.Zig.Toolsets.osx-x64" Version="$(ZigVersion)" GeneratePathProperty="true" />
    <PackageReference Include="Vezel.Zig.Toolsets.osx-arm64" Version="$(ZigVersion)" GeneratePathProperty="true" />
    <PackageReference Include="XWin.Store.x64" Version="$(XWinVersion).$(XWinRevision)" GeneratePathProperty="true" PrivateAssets="none" />
    <PackageReference Include="XWin.Store.arm64" Version="$(XWinVersion).$(XWinRevision)" GeneratePathProperty="true" PrivateAssets="none" />
    <PackageReference Include="LLD.Link.Toolsets.win-x64" Version="$(LLDVersion).$(LLDRevision)" GeneratePathProperty="true" />
    <PackageReference Include="LLD.Link.Toolsets.linux-x64" Version="$(LLDVersion).$(LLDRevision)" GeneratePathProperty="true" />
    <PackageReference Include="LLD.Link.Toolsets.win-arm64" Version="$(LLDVersion).$(LLDRevision)" GeneratePathProperty="true" />
    <PackageReference Include="LLD.Link.Toolsets.linux-arm64" Version="$(LLDVersion).$(LLDRevision)" GeneratePathProperty="true" />
    <PackageReference Include="LLD.Link.Toolsets.osx-arm64" Version="$(LLDVersion).$(LLDRevision)" GeneratePathProperty="true" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Fallenwood.PublishAotCross.props">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="ZigVersion.props">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="Fallenwood.PublishAotCross.targets">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="Crosscompile.targets">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="clang.cmd">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="clang.ps1">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="../README.md">
      <Pack>true</Pack>
      <PackagePath>/</PackagePath>
    </None>
    <None Include="clang">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="gcc">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="objcopy">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>
    <None Include="llvm-objcopy.exe">
      <Pack>true</Pack>
      <PackagePath>build</PackagePath>
    </None>

    <None Include="Scripts/SetPath.cs">
      <Pack>true</Pack>
      <PackagePath>build/Scripts/SetPath.cs</PackagePath>
    </None>
  </ItemGroup>
</Project>
